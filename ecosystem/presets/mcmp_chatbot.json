      "data": {
        "kind": "Context",
        "name": "leopold_personality",
        "description": "Leopold persona definition: identity, philosophical tone, scope boundaries, and behavioral guidelines injected into the system prompt.",
        "content": "prompts/personality.md — Leopold's identity, tone, and response constraints. Separates chatbot character from engine logic."
      }
    },
    {
      "id": "tool_search_people",
      "type": "Tool",
      "position": { "x": 650, "y": 80 },
      "data": {
        "kind": "Tool",
        "name": "search_people",
        "description": "Searches people.json for MCMP researchers by name, role, or research area. Returns full profiles including email, office, publications.",
        "code": "    # src/mcp/tools.py\n    return search_json('data/people.json', query)"
      }
    },
    {
      "id": "tool_search_research",
      "type": "Tool",
