      "data": {
        "kind": "Human",
        "name": "user_query",
        "description": "MCMP website visitor asking about events, people, or research topics via the Streamlit chat interface.",
        "prompt": "Ask me about MCMP events, researchers, or philosophy topics."
      }
    },
    {
      "id": "leopold",
      "type": "LlmAgent",
      "position": { "x": 320, "y": 300 },
      "data": {
        "kind": "LlmAgent",
        "name": "leopold",
        "model": "gemini-2.5-flash",
        "description": "Leopold — MCMP Philosophy Assistant. Answers questions about events, people, and research using MCP-backed structured data tools.",
        "instruction": "You are Leopold, the MCMP Philosophy Assistant. Use the available tools to answer questions about MCMP events, people, and research topics. Always use tools for structured data queries rather than relying on general knowledge.",
        "output_key": "response"
      }
    },
    {
