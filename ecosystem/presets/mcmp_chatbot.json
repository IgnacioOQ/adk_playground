        "kind": "Tool",
        "name": "get_events",
        "description": "Retrieves upcoming MCMP events from raw_events.json. Supports date-range and keyword filtering.",
        "code": "    # src/mcp/tools.py\n    return filter_events('data/raw_events.json', query)"
      }
    },
