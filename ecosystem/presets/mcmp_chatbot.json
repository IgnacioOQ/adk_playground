      "data": {
        "kind": "Tool",
        "name": "search_research",
        "description": "Searches research.json for MCMP research areas and subtopics. Returns hierarchical structure linking topics to people.",
        "code": "    # src/mcp/tools.py\n    return search_json('data/research.json', query)"
      }
    },
    {
      "id": "tool_get_events",
